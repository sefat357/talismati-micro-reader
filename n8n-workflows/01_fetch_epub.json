{
  "name": "Fetch EPUB (File Ingestion)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "fetch-epub",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-fetch-epub",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "webhookId": "fetch-epub"
